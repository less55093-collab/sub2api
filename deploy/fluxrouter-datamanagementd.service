[Unit]
Description=FluxRouter Data Management Daemon
After=network.target
Wants=network.target

[Service]
Type=simple
User=fluxrouter
Group=fluxrouter
WorkingDirectory=/opt/fluxrouter
ExecStart=/opt/fluxrouter/datamanagementd \
  -socket-path /tmp/fluxrouter-datamanagement.sock \
  -sqlite-path /var/lib/fluxrouter/datamanagement/datamanagementd.db \
  -version 1.0.0
Restart=always
RestartSec=5s
LimitNOFILE=100000
NoNewPrivileges=true
PrivateTmp=false

[Install]
WantedBy=multi-user.target
